# ===========================================
# Environment Variables for Task Tracker
# ===========================================
# To use this file:
#   1. Copy it and rename the copy to ".env"
#   2. Fill in the actual values
#   3. NEVER commit the .env file to Git
#
# Why we do this:
#   - .env holds real secrets (passwords, keys)
#   - .env.example is a safe template with fake/empty values
#   - This way, new developers know what variables they need
#     without seeing your actual secrets

# The port your server will run on (default: 3000)
PORT=3000

# Database file path
DATABASE_PATH=./backend/database/tasks.db
